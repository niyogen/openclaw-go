# Normalise line endings to LF in the repo; checkout uses the OS default.
* text=auto eol=lf

# Shell scripts always LF.
*.sh text eol=lf

# Explicitly text files.
*.go   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.mod  text eol=lf
*.sum  text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# PowerShell — keep CRLF on checkout for Windows.
*.ps1 text eol=crlf

# Binaries — never touch.
*.exe binary
dist/openclaw binary
