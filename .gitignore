# Build artefacts — only the compiled binaries, not source directories
dist/
dist/openclaw
dist/openclaw.exe

# Stray plugin binaries from `go build` inside plugin dirs (e.g.
# `go build ./plugins/telegram` drops telegram.exe in the repo root on
# Windows). Plugin binaries are not source.
/telegram.exe
/whatsapp.exe
plugins/*/*.exe

# Local data and secrets (never commit)
*.env
.env.*

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Playwright (e2e-ui)
e2e-ui/node_modules/
e2e-ui/playwright-report/
e2e-ui/test-results/
e2e-ui/blob-report/
